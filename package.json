{
  "name": "koan-astro",
  "version": "0.1.0",
  "description": "Reusable Astro component templates.",
  "type": "module",
  "files": [
    "src/index.ts",
    "src/components",
    "src/assets",
    "src/styles",
    "README.md"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./components/*": "./src/components/*",
    "./assets/icons.svg": "./src/assets/icons.svg",
    "./styles/*": "./src/styles/*",
    "./styles/layout-primitives.css": "./src/styles/layout-primitives.css",
    "./styles/scheme-default.css": "./src/styles/scheme-default.css",
    "./styles/animations.css": "./src/styles/animations.css",
    "./styles/build-in.css": "./src/styles/build-in.css",
    "./styles/elements.css": "./src/styles/elements.css",
    "./styles/lighting.css": "./src/styles/lighting.css"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "check": "astro check",
    "prepack": "npm run check && npm run build",
    "dry": "npm pack --dry-run && echo 'Dry run complete. No files were actually packed.' && echo 'If everything looks good:' && echo '  npm version [major|minor|patch]' && echo '  npm publish'"
  },
  "peerDependencies": {
    "astro": "^4.0.0 || ^5.0.0"
  },
  "devDependencies": {
    "astro": "^5.10.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9"
  }
}
