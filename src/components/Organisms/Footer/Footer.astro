---
import "./Footer.css";
import Logo from '../../Atoms/Logo/Logo.astro';
import Nav from '../../Molecules/Nav/Nav.astro';
import NavItem from '../../Atoms/NavItem/NavItem.astro';
import Section from '../Section/Section.astro';

interface Props {
  variant?: string;
  measure?: string;
}

const { variant = "default", measure = "50ch"} = Astro.props;
const classes = `footer footer--${variant}`;
---

<Section
  className={classes}
  justify="center"
  align="center"
  bgColor="dark"
>
  <div class="grid">
    <Logo variant="default" />
    <div>
      <div class="cluster">
        <NavItem uri="https://sleepingmonk.github.io/koan" label="Documentation" external={true}/>
        <NavItem uri="https://bionic.studio" label="Bionic Studio" external={true}/>
        <NavItem uri="#" label="#home" />
      </div>
    </div>
    <div>
      <p>Bionic Studio is a division of Bionic Entrepreneur Incorporated.</p>
      <p>All words, images and media are the property of Bionic Entrepreneur Incorporated, unless otherwise noted.</p>
      <p>&copy; 2006 - {new Date().getFullYear()} Bionic Entrepreneur Incorporated. All rights reserved.</p>
      <p><small>Stock images provided by <a href="https://unsplash.com/">Unsplash</a></small></p>
    </div>
  </div>
</Section>
